      "children": [
        "schemas.ts",
        "validators.ts",
        "parser.ts"
      ]
    },
    "scripts/generator": {
      "description": "Generation pipeline tools",
      "children": [
        "ingest",
        "convert",
        "emit",
        "shared"
      ]
    },
