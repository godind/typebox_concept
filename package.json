{
  "name": "typebox_concept",
  "version": "1.0.0",
  "description": "Signal K TypeBox validation library with smoke-test client",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    }
  },
  "files": [
    "dist/lib"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && node converter/app/processors/generate-runtime-format-module.mjs && tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json --noEmit && node --import tsx --test",
    "schemas:build": "node converter/app/cli/build.mjs",
    "schemas:snapshot": "node converter/app/cli/snapshot.mjs",
    "schemas:compare": "node converter/app/cli/build-compare.mjs",
    "schemas:verify": "node converter/app/cli/verify.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "typebox": "^1.1.20"
  },
  "optionalDependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
